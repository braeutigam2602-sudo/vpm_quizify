# Python
__pycache__/
*.pyc
*.pyo

# secrets — never commit
.env
.env.*

# large binary assets live in Supabase Storage, not in git (manifest.json IS tracked)
assets/**/*.png
assets/**/*.jpg
assets/**/*.jpeg
assets/**/*.webm
assets/**/*.mp4
assets/**/*.mov
!assets/**/manifest.json

# cue_service Runtime (nie committen)
services/cue_service/*.log
services/cue_service/__pycache__/
